---
import type { Site, ProjectSection } from "../data/content";
export interface Props {
  site: Site;
  projects: ProjectSection[];
  title?: string;
  lang?: "en" | "he";
  aboutLabel?: string;
  projectsLabel?: string;
  soloExhibitionsLabel?: string;
  switchHref?: string;
  switchLabel?: string;
}
const {
  site,
  projects,
  title = site.name,
  lang = "en",
  aboutLabel = "About and Contact Me",
  projectsLabel = "Selected Series",
  soloExhibitionsLabel = "Solo Exhibitions",
  switchHref = "/he",
  switchLabel = "עברית",
} = Astro.props;
const dir = lang === "he" ? "rtl" : "ltr";
---
<!DOCTYPE html>
<html lang={lang} dir={dir}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Hebrew:wght@300;400;500;600;700&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <header>
    <div class="nav-wrap">
      <a class="brand" href="#top">{site.name}</a>
      <nav>
        <ul>
          <li class="dropdown">
            <button class="dropdown-trigger" type="button" aria-haspopup="true" aria-expanded="false">
              {projectsLabel} <span class="caret">▾</span>
            </button>
            <ul class="dropdown-menu">
              {projects.map((p) => (
                <li><a href={`#${p.id}`}>{p.title}{p.badge && <span class="badge">{p.badge}</span>}</a></li>
              ))}
            </ul>
          </li>
          <li><a href="#solo-exhibitions">{soloExhibitionsLabel}</a></li>
          <li><a href="#about">{aboutLabel}</a></li>
          <li><a class="lang-switch" href={switchHref}>{switchLabel}</a></li>
        </ul>
      </nav>
    </div>
  </header>
  <slot />
  <footer>
    <p>© 2026, {site.name} · <a href={`mailto:${site.email}`}>{site.email}</a></p>
  </footer>

  <div class="lightbox" id="lightbox" aria-hidden="true">
    <button class="lightbox-close" type="button" aria-label="Close">&times;</button>
    <figure>
      <img id="lightbox-img" src="" alt="" />
      <figcaption id="lightbox-caption"></figcaption>
    </figure>
  </div>

  <script>
    const dropdown = document.querySelector(".dropdown");
    const dropdownTrigger = document.querySelector(".dropdown-trigger");

    function closeDropdown() {
      dropdown?.classList.remove("open");
      dropdownTrigger?.setAttribute("aria-expanded", "false");
    }

    dropdownTrigger?.addEventListener("click", (e) => {
      e.stopPropagation();
      const isOpen = dropdown?.classList.toggle("open");
      dropdownTrigger.setAttribute("aria-expanded", isOpen ? "true" : "false");
    });

    document.querySelector(".dropdown-menu")?.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).closest("a")) closeDropdown();
    });

    document.addEventListener("click", (e) => {
      if (!dropdown?.contains(e.target as Node)) closeDropdown();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeDropdown();
    });

    const lightbox = document.getElementById("lightbox")!;
    const lbImg = document.getElementById("lightbox-img") as HTMLImageElement;
    const lbCaption = document.getElementById("lightbox-caption")!;

    function openLightbox(img: HTMLImageElement) {
      lbImg.src = img.src;
      lbImg.alt = img.alt;
      const figcaption = img.parentElement?.querySelector("figcaption");
      lbCaption.innerHTML = figcaption ? figcaption.innerHTML : "";
      lightbox.classList.add("open");
      lightbox.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
    }

    function closeLightbox() {
      lightbox.classList.remove("open");
      lightbox.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      lbImg.src = "";
    }

    document.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      const img = target.closest(".gallery figure img") as HTMLImageElement | null;
      if (img) {
        openLightbox(img);
        return;
      }
      if (target === lightbox || target.closest(".lightbox-close")) {
        closeLightbox();
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeLightbox();
    });
  </script>
</body>
</html>

<style is:global>
  :root{
    --bg:#faf8f4;
    --bg-alt:#f0ede5;
    --text:#232019;
    --muted:#6e6555;
    --accent:#a97a1f;
    --line:#e2ddd0;
    --maxw:1180px;
  }
  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    margin:0;
    background:var(--bg);
    color:var(--text);
    font-family: "Georgia", "Times New Roman", serif;
    line-height:1.6;
  }
  html[dir="rtl"] body{
    font-family: "IBM Plex Sans Hebrew", "Georgia", sans-serif;
  }
  header{
    position:sticky; top:0; z-index:50;
    background:rgba(250,248,244,0.92);
    backdrop-filter:blur(6px);
    border-bottom:1px solid var(--line);
  }
  .nav-wrap{
    max-width:var(--maxw); margin:0 auto; padding:16px 24px;
    display:flex; align-items:center; justify-content:space-between;
    flex-wrap:wrap; gap:10px;
  }
  .brand{ font-size:1.3rem; letter-spacing:0.04em; color:var(--text); text-decoration:none; }
  nav ul{ list-style:none; display:flex; gap:22px; margin:0; padding:0; flex-wrap:wrap; }
  nav a{ color:var(--muted); text-decoration:none; font-size:0.92rem; letter-spacing:0.03em; text-transform:uppercase; }
  nav a:hover{ color:var(--accent); }
  nav a.lang-switch{ color:var(--accent); border:1px solid var(--accent); padding:3px 10px; border-radius:2px; }
  nav a.lang-switch:hover{ color:var(--bg); background:var(--accent); }
  .dropdown{ position:relative; }
  .dropdown-trigger{
    background:none; border:none; padding:0; margin:0; cursor:pointer;
    color:var(--muted); font:inherit; font-size:0.92rem; letter-spacing:0.03em; text-transform:uppercase;
    display:inline-flex; align-items:center; gap:5px;
  }
  .dropdown-trigger:hover{ color:var(--accent); }
  .dropdown.open .dropdown-trigger{ color:var(--accent); }
  .caret{ font-size:0.7em; transition:transform 0.15s ease; }
  .dropdown.open .caret{ transform:rotate(180deg); }
  .dropdown-menu{
    display:none; position:absolute; top:100%; inset-inline-start:0; margin-top:16px;
    background:var(--bg); border:1px solid var(--line); box-shadow:0 16px 36px rgba(20,17,10,0.14);
    min-width:260px; max-width:320px; padding:8px; list-style:none; z-index:60;
  }
  .dropdown.open .dropdown-menu{ display:block; }
  .dropdown-menu li{ margin:0; }
  .dropdown-menu a{
    display:flex; align-items:center; padding:10px 12px; border-radius:2px;
    text-transform:none; letter-spacing:0.01em; font-size:0.98rem; white-space:nowrap;
  }
  .dropdown-menu a:hover{ background:var(--bg-alt); color:var(--accent); }
  .dropdown-menu .badge{ margin-inline-start:8px; }
  section{ max-width:var(--maxw); margin:0 auto; padding:80px 24px; border-bottom:1px solid var(--line); }
  section:last-of-type{ border-bottom:none; }
  h2.section-title{ font-size:2rem; font-weight:400; margin:0 0 6px; }
  .section-meta{ color:var(--accent); text-transform:uppercase; letter-spacing:0.08em; font-size:0.82rem; margin-bottom:28px; }
  .statement{ color:var(--muted); max-width:760px; margin-bottom:36px; font-size:1rem; }
  .statement p{ margin:0 0 16px; }
  .gallery{ display:grid; grid-template-columns: repeat(auto-fill,minmax(280px,1fr)); gap:28px; }
  figure{ margin:0; }
  figure img{
    width:100%; height:320px; object-fit:cover; display:block;
    border:1px solid var(--line); background:var(--bg-alt);
    transition:opacity 0.2s ease; cursor:zoom-in;
  }
  figure img:hover{ opacity:0.85; }
  figcaption{ margin-top:10px; color:var(--muted); font-size:0.9rem; }
  figcaption .title{ color:var(--text); display:block; margin-bottom:2px; }
  footer{ text-align:center; padding:48px 24px; color:var(--muted); font-size:0.9rem; }
  footer a{ color:var(--accent); text-decoration:none; }
  .badge{
    display:inline-block; font-size:0.7rem; letter-spacing:0.05em; text-transform:uppercase;
    color:#fff; background:var(--accent); padding:2px 8px; border-radius:2px; margin-inline-start:8px; vertical-align:middle;
  }
  .hero{
    position:relative; height:78vh; min-height:440px;
    display:flex; flex-direction:column; justify-content:flex-end;
    background:var(--bg-alt); overflow:hidden;
  }
  .hero img{ position:absolute; inset:0; width:100%; height:100%; object-fit:cover; }
  .hero-inner{
    position:relative; z-index:1; width:100%;
    background:rgba(250,248,244,0.95); backdrop-filter:blur(6px);
    border-top:1px solid var(--line);
    box-shadow:0 -6px 24px rgba(20,17,10,0.08);
  }
  .hero-text{ max-width:var(--maxw); margin:0 auto; padding:28px 24px 32px; }
  .hero h1{ font-size:clamp(2.4rem,6vw,4.2rem); margin:0 0 8px; font-weight:400; letter-spacing:0.02em; color:var(--text); }
  .hero p{ color:var(--muted); font-size:1.05rem; margin:0; max-width:560px;}
  .about-grid{ display:grid; grid-template-columns: 260px 1fr; gap:40px; align-items:start; }
  .about-grid img{ width:100%; border-radius:2px; }
  .about-grid .bio p{ color:var(--muted); margin:0 0 16px; }
  @media (max-width:640px){ .about-grid{ grid-template-columns:1fr; } }

  .lightbox{
    display:none; position:fixed; inset:0; z-index:200;
    background:rgba(15,13,10,0.94);
    padding:56px 24px;
    align-items:center; justify-content:center;
  }
  .lightbox.open{ display:flex; }
  .lightbox figure{ display:flex; flex-direction:column; align-items:center; max-width:min(92vw,1100px); max-height:100%; margin:0; }
  .lightbox img{
    max-width:100%; max-height:78vh; width:auto; height:auto;
    object-fit:contain; display:block;
    box-shadow:0 20px 60px rgba(0,0,0,0.5);
  }
  .lightbox figcaption{ color:#f1ede4; margin-top:18px; text-align:center; font-size:0.95rem; }
  .lightbox figcaption .title{ color:#fff; display:block; margin-bottom:4px; font-size:1.05rem; }
  .lightbox-close{
    position:absolute; top:20px; inset-inline-end:24px;
    background:none; border:1px solid rgba(255,255,255,0.35); color:#fff;
    font-size:1.6rem; line-height:1; width:44px; height:44px; border-radius:50%;
    cursor:pointer; display:flex; align-items:center; justify-content:center;
  }
  .lightbox-close:hover{ background:rgba(255,255,255,0.12); }
</style>
